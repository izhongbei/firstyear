---
import Section from './Section.astro';
import Button from './Button.astro';
import MarkdownBody from './MarkdownBody.astro';

type AstroComponentFactory = (props?: Record<string, unknown>) => any;

interface Props {
  title: string;
  headline: string;
  subheadline: string;
  Content: AstroComponentFactory;
  ctaLabel: string;
  city: string;
  ageRange: string;
}

const { title, headline, subheadline, Content, ctaLabel, city, ageRange } = Astro.props;
---

<section class="section section--hero" id="hero" aria-labelledby="hero-heading">
  <div class="container hero-layout">
    <div class="hero">
      <p class="hero-meta">{city} · {ageRange}</p>
      <h1 id="hero-heading" class="hero-headline">{headline}</h1>
      <p class="hero-sub">{subheadline}</p>
      <MarkdownBody Content={Content} class="hero-body" />
      <Button variant="primary" data-open-modal="qr-modal">{ctaLabel}</Button>
    </div>
    <div class="hero-visual" aria-hidden="true">
      <img src="/images/hero-accent.svg" alt="" width="320" height="240" loading="eager" />
    </div>
  </div>
</section>

<style>
  .hero-layout {
    display: grid;
    gap: 2rem;
    align-items: center;
  }
  @media (min-width: 1024px) {
    .hero-layout {
      grid-template-columns: 1fr minmax(200px, 320px);
    }
  }
  .hero {
    text-align: center;
    max-width: 36rem;
  }
  @media (min-width: 1024px) {
    .hero {
      text-align: left;
      margin-inline: 0;
    }
  }
  @media (max-width: 1023px) {
    .hero {
      margin-inline: auto;
    }
  }
  .hero-meta {
    display: inline-block;
    margin: 0 0 1rem;
    padding: 0.25rem 0.75rem;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-text-muted);
    background: var(--color-surface);
  }
  .hero-headline {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.2;
    margin: 0 0 1rem;
    color: var(--color-text);
  }
  .hero-sub {
    color: var(--color-text-muted);
    font-size: 1.125rem;
    margin: 0 0 1.25rem;
    line-height: 1.6;
  }
  .hero-body {
    margin: 0 0 1.75rem;
    text-align: inherit;
    color: var(--color-text-muted);
  }
  .hero-visual {
    display: none;
    justify-content: center;
  }
  @media (min-width: 1024px) {
    .hero-visual {
      display: flex;
    }
  }
  #hero-heading:focus {
    outline: 2px solid var(--color-primary);
    outline-offset: 4px;
  }
</style>
