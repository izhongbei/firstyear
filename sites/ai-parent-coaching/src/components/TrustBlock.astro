---
import Section from './Section.astro';
import MarkdownBody from './MarkdownBody.astro';

type AstroComponentFactory = (props?: Record<string, unknown>) => any;

interface Comparison {
  vs: string;
  point: string;
}

interface Props {
  title: string;
  comparisons: Comparison[];
  disclaimer: string;
  expertNote: string;
  Content: AstroComponentFactory;
}

const { title, comparisons, disclaimer, expertNote, Content } = Astro.props;
---

<Section id="trust" title={title} tabindex={-1}>
  <div class="trust-grid">
    {comparisons.map((c) => (
      <article class="card trust-card">
        <span class="trust-check" aria-hidden="true">✓</span>
        <div>
          <h3 class="trust-vs">相比 {c.vs}</h3>
          <p class="trust-point">{c.point}</p>
        </div>
      </article>
    ))}
  </div>
  <p class="expert-note">{expertNote}</p>
  <aside class="disclaimer card" role="note">
    <p>{disclaimer}</p>
  </aside>
  <MarkdownBody Content={Content} class="trust-body" />
</Section>

<style>
  .trust-grid {
    display: grid;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }
  @media (min-width: 768px) {
    .trust-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  .trust-card {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
    padding: 1.25rem;
  }
  .trust-check {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border-radius: 50%;
    background: rgba(123, 174, 127, 0.12);
    color: var(--color-secondary);
    font-weight: 700;
    font-size: 0.875rem;
  }
  .trust-vs {
    margin: 0 0 0.35rem;
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-text);
  }
  .trust-point {
    margin: 0;
    font-size: 0.9rem;
    color: var(--color-text-muted);
    line-height: 1.55;
  }
  .expert-note {
    font-style: normal;
    color: var(--color-text-muted);
    font-size: 0.95rem;
    margin: 0 0 1rem;
  }
  .disclaimer {
    background: var(--color-surface);
    border-color: var(--color-border);
    margin: 0 0 1rem;
  }
  .disclaimer p {
    margin: 0;
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }
  .trust-body {
    margin-top: 0.5rem;
    color: var(--color-text-muted);
  }
</style>
